{
  "name": "incodex",
  "version": "0.1.2",
  "description": "web for codex ",
  "keywords": [
    "browser",
    "cli",
    "codex",
    "macos",
    "openai",
    "wsl"
  ],
  "homepage": "https://github.com/ip2a/incodex",
  "bugs": {
    "url": "https://github.com/ip2a/incodex/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "ip2a",
    "email": "ooooofish@126.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ip2a/incodex.git"
  },
  "bin": {
    "incodex": "./dist/cli.js"
  },
  "files": [
    "dist/**",
    "LICENSE",
    "README.md"
  ],
  "os": [
    "darwin",
    "linux"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && pnpm exec tsgo -p tsconfig.json && pnpm run build:static",
    "build:static": "mkdir -p dist/images && cp src/incodex.css dist/incodex.css && cp src/images/import.svg dist/images/import.svg",
    "check:commit": "pnpm run fmt:check && pnpm run lint && pnpm run typecheck",
    "check": "pnpm run fmt:check && pnpm run lint && pnpm run typecheck && pnpm test",
    "commitmsg": "commitlint --edit",
    "dev": "tsx src/cli.ts --dev",
    "dev:watch": "tsx watch src/cli.ts --dev",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --fix .",
    "prepare": "simple-git-hooks",
    "prepack": "pnpm run build",
    "pack:check": "npm pack --dry-run",
    "release:patch": "npm version patch -m \"chore(release): %s\"",
    "release:minor": "npm version minor -m \"chore(release): %s\"",
    "release:major": "npm version major -m \"chore(release): %s\"",
    "smoke:all": "pnpm run smoke:boot && pnpm run smoke:webkit && pnpm run smoke:ui && pnpm run smoke:mobile && pnpm run smoke:tools && pnpm run smoke:tool-switch && pnpm run smoke:pwa && pnpm run smoke:https && pnpm run smoke:reconnect",
    "smoke:boot": "node scripts/mobile-boot-smoke.mjs",
    "smoke:dist": "pnpm run build && node scripts/dist-boot-smoke.mjs",
    "smoke:https": "pnpm run build && node scripts/https-smoke.mjs",
    "smoke:lan": "pnpm run build && node scripts/dist-boot-smoke.mjs --lan",
    "smoke:mobile": "node scripts/mobile-smoke.mjs",
    "smoke:pwa": "pnpm run build && node scripts/pwa-smoke.mjs",
    "smoke:reconnect": "pnpm run build && node scripts/reconnect-smoke.mjs",
    "smoke:tool-switch": "node scripts/mobile-tool-switch-smoke.mjs",
    "smoke:tools": "node scripts/mobile-tools-smoke.mjs",
    "smoke:ui": "node scripts/mobile-ui-smoke.mjs",
    "smoke:webkit": "node scripts/mobile-webkit-boot-smoke.mjs",
    "test": "pnpm run build && vitest run ./test --passWithNoTests",
    "typecheck": "pnpm exec tsgo --noEmit"
  },
  "dependencies": {
    "@electron/asar": "^4.1.0",
    "mime-types": "^3.0.2",
    "node-gyp": "^12.2.0",
    "node-pty": "^1.1.0",
    "plist": "^3.1.0",
    "smol-toml": "^1.6.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.3.5",
    "@types/plist": "^3.0.5",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "^7.0.0-dev.20260312.1",
    "oxfmt": "^0.39.0",
    "oxlint": "^1.54.0",
    "playwright": "^1.58.2",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm run commitmsg -- $1",
    "pre-commit": "pnpm run check:commit"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.9.0"
}
